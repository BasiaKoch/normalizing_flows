# Ignore markdown files
*.md

# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.DS_Store

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# Generated coursework artifacts
figs/*
checkpoints/*
logs/*
results.json

# Keep directories themselves; do not ignore data contents
!figs/.gitkeep
!checkpoints/.gitkeep
!logs/.gitkeep
